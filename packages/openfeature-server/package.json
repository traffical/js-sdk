{
  "name": "@traffical/openfeature-server",
  "version": "0.1.0",
  "description": "OpenFeature server (dynamic-context) provider backed by the Traffical Node SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@traffical/core": "0.10.0",
    "@traffical/openfeature-core": "0.1.0",
    "@traffical/node": "0.9.0"
  },
  "peerDependencies": {
    "@openfeature/server-sdk": "^1.22.0"
  },
  "devDependencies": {
    "@openfeature/core": "^1.11.0",
    "@openfeature/server-sdk": "^1.22.0",
    "@traffical/sdk-spec": "^0.5.0",
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "traffical",
    "feature-flags",
    "experimentation",
    "a/b-testing",
    "openfeature",
    "provider"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/traffical/js-sdk"
  },
  "publishConfig": {
    "access": "public"
  }
}
