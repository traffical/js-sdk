{
  "name": "@traffical/react",
  "version": "0.6.2",
  "description": "Traffical SDK for React - Provider and hooks for parameter resolution",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@traffical/core": "0.11.0",
    "@traffical/js-client": "0.16.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^15",
    "@testing-library/react": "^16",
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "react-dom": "19.2.3",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "19.2.3"
  },
  "keywords": [
    "traffical",
    "feature-flags",
    "experimentation",
    "a/b-testing",
    "react",
    "hooks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/traffical/js-sdk"
  },
  "publishConfig": {
    "access": "public"
  }
}
